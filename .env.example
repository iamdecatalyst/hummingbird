# ── Solana ────────────────────────────────────────────────────────────────────
# Use a private RPC for best speed (Helius, QuickNode, Triton)
RPC_WS=wss://api.mainnet-beta.solana.com
RPC_HTTP=https://api.mainnet-beta.solana.com

# ── Platforms — Solana ────────────────────────────────────────────────────────
ENABLE_PUMP_FUN=true           # pump.fun (default: on)
ENABLE_MOONSHOT=false          # DEX Screener's Moonshot
ENABLE_RAYDIUM_LAUNCHLAB=false # Raydium LaunchLab
ENABLE_BOOP=false              # Boop.fun

# Override program IDs if they ever change (defaults are mainnet addresses)
# PUMP_FUN_PROGRAM=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
# MOONSHOT_PROGRAM=MoonCVVNZFSYkqNXP6bxHLPL6QQJiMagDL3qcqUQTrG
# RAYDIUM_LAUNCHLAB_PROGRAM=LanMV9sAd7wArD4vsbMervnLNMmHVCBYYMBVAGHPRbm
# BOOP_PROGRAM=boopkpWqe68MSxLqBGogs8ZbUDN4GXaLhFwNcMWrS8D

# ── Platforms — Base (L2) ─────────────────────────────────────────────────────
ENABLE_BASE_PUMP_FUN=false
ENABLE_VIRTUALS=false

# BASE_RPC_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_HTTP=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_PUMP_FUN_FACTORY=0x...
# BASE_PUMP_FUN_TOPIC=0x...
# VIRTUALS_FACTORY=0x...
# VIRTUALS_TOPIC=0x...

# ── Platforms — BNB Chain ─────────────────────────────────────────────────────
ENABLE_FOUR_MEME=false

# BNB_RPC_WS=wss://bsc-ws-node.nariox.org:443
# BNB_RPC_HTTP=https://bsc-dataseed.binance.org
# FOUR_MEME_FACTORY=0x...
# FOUR_MEME_TOPIC=0x...

# ── Scorer ────────────────────────────────────────────────────────────────────
SCORER_URL=http://localhost:8001

# ── Signet (for orchestrator) ─────────────────────────────────────────────────
SIGNET_API_KEY=sk_live_...
SIGNET_API_SECRET=ss_live_...

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
